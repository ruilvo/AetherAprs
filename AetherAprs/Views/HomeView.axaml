<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AetherAprs.ViewModels"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AetherAprs.Views.HomeView"
x:DataType="vm:HomeViewModel"
             MarkerLocation="{Binding MarkerLocation}">

    <Grid RowDefinitions="*">
        <mapsui:MapControl Grid.Row="1"
                           x:Name="MapControl"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch" />
    </Grid>
</UserControl>
