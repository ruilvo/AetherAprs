<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AetherAprs.ViewModels"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:controls="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AetherAprs.Views.MainView"
             x:DataType="vm:MainViewModel">
    <controls:NavigationDrawer LeftDrawerOpened="{Binding ElementName=NavDrawerSwitch, Path=IsChecked, Mode=TwoWay}">
        <controls:NavigationDrawer.LeftDrawerContent>
            <StackPanel Spacing="4" Margin="0,8">
                <Button Theme="{StaticResource MaterialFlatButton}"
                        Command="{Binding NavigateHomeCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <icons:MaterialIcon Kind="Home" Width="24" Height="24" />
                        <TextBlock Text="Home" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Theme="{StaticResource MaterialFlatButton}"
                        Command="{Binding NavigateSettingsCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <icons:MaterialIcon Kind="Settings" Width="24" Height="24" />
                        <TextBlock Text="Settings" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </controls:NavigationDrawer.LeftDrawerContent>
        <Grid RowDefinitions="Auto, *">
            <StackPanel Grid.Row="0" Spacing="4" Orientation="Horizontal">
                <ToggleButton Name="NavDrawerSwitch"
                              WindowDecorationProperties.ElementRole="DecorationsElement"
                              Theme="{StaticResource MaterialFlatButton}"
                              Width="32" Height="32" Padding="4">
                    <icons:MaterialIcon Kind="Menu" Width="24" Height="24" />
                </ToggleButton>
                <TextBlock VerticalAlignment="Center" Text="Aether APRS"/>
            </StackPanel>

            <!-- Screen Page Content Layout -->
            <ContentControl Grid.Row="1" Content="{Binding NavService.CurrentView}" />
        </Grid>
    </controls:NavigationDrawer>


</UserControl>
